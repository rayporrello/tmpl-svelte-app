{
  "name": "tmpl-svelte-app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "prebuild": "bun run scripts/optimize-images.js",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "eslint .",
    "format": "prettier --write .",
    "images:optimize": "bun run scripts/optimize-images.js",
    "check:seo": "bun run scripts/check-seo.ts",
    "seo:check": "bun run check:seo",
    "validate": "bun run check && bun run images:optimize && bun run build && bun run check:seo"
  },
  "devDependencies": {
    "@fontsource-variable/jetbrains-mono": "^5.1.0",
    "@fontsource-variable/plus-jakarta-sans": "^5.1.0",
    "@sveltejs/enhanced-img": "^0.6.0",
    "@sveltejs/kit": "^2.16.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "glob": "^11.0.0",
    "sharp": "^0.33.0",
    "svelte": "^5.0.0",
    "svelte-adapter-bun": "^0.5.2",
    "svelte-check": "^4.0.0",
    "typescript": "^5.0.0",
    "vite": "^6.0.0"
  }
}
