{
	"name": "tmpl-svelte-app",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"packageManager": "bun@1.3.9",
	"engines": {
		"bun": ">=1.1"
	},
	"scripts": {
		"preinstall": "npx only-allow bun",
		"dev": "vite dev",
		"build": "vite build",
		"prebuild": "bun run scripts/optimize-images.js",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "eslint .",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"images:optimize": "bun run scripts/optimize-images.js",
		"check:seo": "bun run scripts/check-seo.ts",
		"seo:check": "bun run check:seo",
		"check:analytics": "bun run scripts/check-analytics.ts",
		"check:cms": "bun run scripts/check-cms-config.ts",
		"check:content": "bun run scripts/validate-content.ts",
		"check:content-diff": "bun run scripts/check-content-diff.ts",
		"check:assets": "bun run scripts/check-assets.ts",
		"check:design-system": "bun run scripts/check-design-system.ts",
		"check:init-site": "bun run scripts/check-init-site.ts",
		"check:launch": "bun run scripts/check-launch.ts",
		"init:site": "bun run scripts/init-site.ts",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:e2e": "playwright test",
		"test:e2e:built": "PLAYWRIGHT_SKIP_BUILD=1 playwright test",
		"test:e2e:external": "PLAYWRIGHT_BASE_URL=${PLAYWRIGHT_BASE_URL:?set PLAYWRIGHT_BASE_URL} playwright test",
		"validate": "bun run format:check && bun run check && bun run check:seo && bun run check:analytics && bun run check:cms && bun run check:content && bun run check:assets && bun run check:design-system && bun run images:optimize && bun run build && bun run test && bun run test:e2e:built",
		"validate:launch": "bun run validate && bun run check:init-site && bun run check:launch && bun run check:content-diff",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:push": "drizzle-kit push",
		"db:studio": "drizzle-kit studio",
		"db:check": "drizzle-kit check",
		"privacy:prune": "bun run scripts/privacy-prune.ts",
		"secrets:render": "bash scripts/render-secrets.sh",
		"secrets:check": "bash scripts/check-secrets.sh",
		"backup:db": "bash scripts/backup-db.sh",
		"backup:uploads": "bash scripts/backup-uploads.sh",
		"backup:all": "bash scripts/backup-all.sh",
		"backup:push": "bash scripts/backup-push.sh",
		"backup:verify": "bash scripts/verify-backup.sh",
		"restore:db": "bash scripts/restore-db.sh",
		"prepare": "lefthook install 2>/dev/null || true"
	},
	"devDependencies": {
		"@axe-core/playwright": "^4.11.2",
		"@eslint/js": "^10.0.1",
		"@fontsource-variable/jetbrains-mono": "^5.1.0",
		"@fontsource-variable/plus-jakarta-sans": "^5.1.0",
		"@playwright/test": "^1.59.1",
		"@sveltejs/enhanced-img": "^0.6.0",
		"@sveltejs/kit": "^2.16.0",
		"@sveltejs/vite-plugin-svelte": "^5.0.0",
		"@types/js-yaml": "^4.0.9",
		"@types/node": "^25.6.0",
		"@types/sanitize-html": "^2.16.1",
		"drizzle-kit": "^0.31.10",
		"eslint": "^10.2.1",
		"eslint-plugin-svelte": "^3.17.1",
		"glob": "^11.0.0",
		"globals": "^17.5.0",
		"lefthook": "^2.1.6",
		"postcss": "^8.5.12",
		"postcss-safe-parser": "^7.0.1",
		"postcss-value-parser": "^4.2.0",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^3.5.1",
		"sharp": "^0.33.0",
		"svelte": "^5.0.0",
		"svelte-adapter-bun": "^0.5.2",
		"svelte-check": "^4.0.0",
		"sveltekit-superforms": "^2.30.1",
		"typescript": "^5.0.0",
		"typescript-eslint": "^8.59.1",
		"valibot": "^1.3.1",
		"vite": "^6.0.0",
		"vitest": "^4.1.5"
	},
	"dependencies": {
		"cookie": "0.6.0",
		"devalue": "5.7.1",
		"drizzle-orm": "^0.45.2",
		"gray-matter": "^4.0.3",
		"js-yaml": "^4.1.1",
		"marked": "^18.0.2",
		"postgres": "^3.4.9",
		"sanitize-html": "^2.17.3",
		"set-cookie-parser": "3.1.0"
	}
}
