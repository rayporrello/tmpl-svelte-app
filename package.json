{
  "name": "tmpl-svelte-app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.9",
  "engines": {
    "bun": ">=1.1"
  },
  "scripts": {
    "preinstall": "npx only-allow bun",
    "dev": "vite dev",
    "build": "vite build",
    "prebuild": "bun run scripts/optimize-images.js",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "eslint .",
    "format": "prettier --write .",
    "images:optimize": "bun run scripts/optimize-images.js",
    "check:seo": "bun run scripts/check-seo.ts",
    "seo:check": "bun run check:seo",
    "check:cms": "bun run scripts/check-cms-config.ts",
    "check:content": "bun run scripts/validate-content.ts",
    "check:content-diff": "bun run scripts/check-content-diff.ts",
    "check:assets": "bun run scripts/check-assets.ts",
    "check:launch": "bun run scripts/check-launch.ts",
    "init:site": "bun run scripts/init-site.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "validate": "bun run check && bun run check:seo && bun run check:cms && bun run check:content && bun run check:assets && bun run images:optimize && bun run build && bun run test && bun run test:e2e",
    "validate:launch": "bun run validate && bun run check:launch && bun run check:content-diff",
    "secrets:render": "bash scripts/render-secrets.sh",
    "secrets:check": "bash scripts/check-secrets.sh"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.2",
    "@fontsource-variable/jetbrains-mono": "^5.1.0",
    "@fontsource-variable/plus-jakarta-sans": "^5.1.0",
    "@playwright/test": "^1.59.1",
    "@sveltejs/enhanced-img": "^0.6.0",
    "@sveltejs/kit": "^2.16.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.6.0",
    "@types/sanitize-html": "^2.16.1",
    "glob": "^11.0.0",
    "sharp": "^0.33.0",
    "svelte": "^5.0.0",
    "svelte-adapter-bun": "^0.5.2",
    "svelte-check": "^4.0.0",
    "sveltekit-superforms": "^2.30.1",
    "typescript": "^5.0.0",
    "valibot": "^1.3.1",
    "vite": "^6.0.0",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.1",
    "marked": "^18.0.2",
    "sanitize-html": "^2.17.3"
  }
}
