# Containerfile.node.example — REFERENCE-ONLY adapter-node recipe
#
# Status: REFERENCE ONLY. This file is not maintained, not CI-tested, and is
# not guaranteed to build cleanly against the current dependency set. Treat it
# as documentation of the swap shape, not as a working drop-in.
#
# The primary supported runtime is svelte-adapter-bun (see Containerfile and
# ADR-018). If svelte-adapter-bun ever becomes unworkable, this file is a
# starting point — but expect to spend time adapting it (Bun version pin in
# the user-agent guard, dependency install flags, HEALTHCHECK tooling, env
# contract) before it builds.
#
# Swap shape (high level):
#   1. bun add -d @sveltejs/adapter-node
#   2. In svelte.config.js: replace import from 'svelte-adapter-bun' with '@sveltejs/adapter-node'
#   3. Adapt this file into a working Containerfile and verify locally
#   4. BODY_SIZE_LIMIT and other adapter-node env vars become active
#
# Environment variable contract (adapter-node):
#   PORT              — port to listen on (default: 3000)
#   HOST              — bind address (default: 0.0.0.0)
#   ORIGIN            — full origin URL (REQUIRED)
#   BODY_SIZE_LIMIT   — max request body size in bytes (e.g. 524288 = 512 KB)
#   ADDRESS_HEADER    — header for client IP behind proxy
#   XFF_DEPTH         — trusted proxy depth for X-Forwarded-For

# ── Stage 1: builder ──────────────────────────────────────────────────────────
FROM oven/bun:1-alpine AS builder

WORKDIR /app

RUN apk add --no-cache git

COPY package.json bun.lock ./
RUN bun install --frozen-lockfile

COPY . .
RUN bun run build

# ── Stage 2: runtime (Node) ───────────────────────────────────────────────────
FROM node:22-alpine AS runtime

WORKDIR /app

RUN addgroup -g 1001 -S app && adduser -u 1001 -S app -G app

# Install only production dependencies with npm (Node runtime path)
COPY --from=builder --chown=app:app /app/build ./build
COPY --from=builder --chown=app:app /app/package.json ./
RUN npm install --omit=dev --ignore-scripts

USER app

EXPOSE 3000

HEALTHCHECK --interval=10s --timeout=3s --start-period=5s --retries=3 \
  CMD wget -qO- http://127.0.0.1:3000/healthz || exit 1

CMD ["node", "build/index.js"]
