# Public environment contract for this template.
# Do not put real secrets here.
# Real values belong in encrypted secrets.yaml and are rendered to .env locally and at deploy time.
# Copy this to .env only if you are NOT using the SOPS workflow; otherwise use:
#   ./scripts/render-secrets.sh

ORIGIN=https://example.com

# ── Database (required) ──────────────────────────────────────────────────────
# Format: postgres://user:password@host:port/dbname
# Local dev example: postgres://site_user:devpass@127.0.0.1:5432/site_db
# Run migrations after setting: bun run db:migrate
DATABASE_URL=postgres://site_user:replace-me@127.0.0.1:5432/site_db

POSTMARK_SERVER_TOKEN=
CONTACT_TO_EMAIL=
CONTACT_FROM_EMAIL=
SESSION_SECRET=

# n8n automation bridge (optional — site works without these)
# See docs/automations/security-and-secrets.md
N8N_WEBHOOK_URL=
N8N_WEBHOOK_SECRET=

# ── Analytics (public — safe to expose to browser) ──────────────────────────
# See docs/analytics/README.md for the full analytics guide.
# Master switch — set to "true" only for production. Leave false for staging/dev.
PUBLIC_ANALYTICS_ENABLED=false
# GTM web container ID (e.g. GTM-XXXXXXX). Required when analytics is enabled.
PUBLIC_GTM_ID=
# GA4 Measurement ID (e.g. G-XXXXXXXXXX). Informational — GA4 lives inside GTM.
PUBLIC_GA4_MEASUREMENT_ID=
# Cloudflare Web Analytics token — optional privacy-first sanity layer.
PUBLIC_CLOUDFLARE_WEB_ANALYTICS_TOKEN=
# Set to "true" to allow analytics in staging/preview (not recommended).
PUBLIC_ANALYTICS_STAGING_OVERRIDE=false

# ── Analytics (private — server-side conversion events, dormant by default) ──
# See docs/analytics/server-conversions.md before enabling.
ANALYTICS_SERVER_EVENTS_ENABLED=false
# GA4 Measurement ID and API secret for server-side Measurement Protocol events.
# Only needed if using the GA4 MP provider (see ga4-measurement-protocol.example.ts).
GA4_MEASUREMENT_ID=
GA4_MEASUREMENT_PROTOCOL_API_SECRET=
