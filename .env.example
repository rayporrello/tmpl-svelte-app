# Public environment contract for this template.
# Do not put real secrets here.
#
# Production values are rendered by the separate web-data-platform repo.
# Local development may copy this to .env, but ./bootstrap normally creates a
# working local .env with a per-clone Podman Postgres DATABASE_URL.

ORIGIN=https://example.com
PUBLIC_SITE_URL=https://example.com

# ── Shared platform runtime ──────────────────────────────────────────────────
# Production web containers join web-platform.network and reach the shared
# Postgres cluster by hostname. Each client gets its own database and role.
CLIENT_SLUG=example-client
DATABASE_URL=postgres://example_client_app_user:replace-me@web-platform-postgres:5432/example_client_app
DATABASE_POOL_MAX=5
DATABASE_STATEMENT_TIMEOUT_MS=5000

SESSION_SECRET=

# Optional production runtime tuning. Keep this below Podman/Caddy stop timeout.
SHUTDOWN_TIMEOUT_MS=8000

# ── Contact form ─────────────────────────────────────────────────────────────
# Who receives contact form submissions. Required for production Postmark
# delivery; local/dev can omit these and use console logging.
CONTACT_TO_EMAIL=hello@yourdomain.com
CONTACT_FROM_EMAIL=noreply@yourdomain.com

# Transactional email provider. Optional in local/dev and test; required for
# production launch by ADR-024 unless LAUNCH_ALLOW_CONSOLE_EMAIL=1 is set.
# See src/lib/server/forms/providers/ for other provider options.
POSTMARK_SERVER_TOKEN=

# Authenticated E2E deploy smoke (ADR-029). SMOKE_TEST_SECRET is a backdoor
# credential for POST /contact smoke submissions; generate with:
#   openssl rand -hex 32
# Store/rotate it through docs/operations/smoke.md. When set, POSTMARK_API_TEST
# is required so smoke email is accepted by Postmark but not delivered.
SMOKE_TEST_SECRET=
POSTMARK_API_TEST=
SMOKE_TEST_RATE_LIMIT_PER_HOUR=60
SMOKE_TEST_BACKLOG_THRESHOLD=100

# Operator auth for /admin/* at the Caddy layer (ADR-030). Generate with:
#   caddy hash-password
# Store only the hash here/secrets.yaml; never write the cleartext password.
HEALTH_ADMIN_PASSWORD_HASH=

# Explicit production waiver for non-lead-gen variants or temporary repair
# mode. Do not use as the normal launch path.
LAUNCH_ALLOW_CONSOLE_EMAIL=0

# In-process rate limiter (optional — set to "true" to activate).
# Single-node guard only; resets on restart. See docs/design-system/forms-guide.md.
RATE_LIMIT_ENABLED=false

# ── LOCAL-DEV-ONLY automation worker ────────────────────────────────────────
# Production automation provider config belongs to web-data-platform.
# These vars remain so `bun run automation:worker` can deliver local-dev outbox
# events against a local receiver while developing a site.
AUTOMATION_PROVIDER=noop
N8N_WEBHOOK_URL=
N8N_WEBHOOK_SECRET=
N8N_WEBHOOK_AUTH_MODE=header
N8N_WEBHOOK_AUTH_HEADER=X-Site-Auth
AUTOMATION_WEBHOOK_URL=
AUTOMATION_WEBHOOK_SECRET=
AUTOMATION_WEBHOOK_AUTH_MODE=header
AUTOMATION_WEBHOOK_AUTH_HEADER=X-Site-Auth

# ── Analytics (public — safe to expose to browser) ──────────────────────────
# See docs/analytics/README.md for the full analytics guide.
# Master switch — set to "true" only for production. Leave false for staging/dev.
PUBLIC_ANALYTICS_ENABLED=false
# GTM web container ID (e.g. GTM-XXXXXXX). Required when analytics is enabled.
PUBLIC_GTM_ID=
# GA4 Measurement ID (e.g. G-XXXXXXXXXX). Informational — GA4 lives inside GTM.
PUBLIC_GA4_MEASUREMENT_ID=
# Cloudflare Web Analytics token — optional privacy-first sanity layer.
PUBLIC_CLOUDFLARE_WEB_ANALYTICS_TOKEN=
# Set to "true" to allow analytics in staging/preview (not recommended).
PUBLIC_ANALYTICS_STAGING_OVERRIDE=false

# ── Analytics (private — server-side conversion events, dormant by default) ──
# See docs/analytics/server-conversions.md before enabling.
ANALYTICS_SERVER_EVENTS_ENABLED=false
# GA4 Measurement ID and API secret for server-side Measurement Protocol events.
# Only needed if using the GA4 MP provider (see ga4-measurement-protocol.example.ts).
GA4_MEASUREMENT_ID=
GA4_MEASUREMENT_PROTOCOL_API_SECRET=
