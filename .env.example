# Public environment contract for this template.
# Do not put real secrets here.
# Real values belong in encrypted secrets.yaml and are rendered to .env locally and at deploy time.
# Copy this to .env only if you are NOT using the SOPS workflow; otherwise use:
#   ./scripts/render-secrets.sh

ORIGIN=https://example.com
PUBLIC_SITE_URL=https://example.com

# ── Database (required) ──────────────────────────────────────────────────────
# Production runtime format: postgres://<project>_app_user:password@<project>-postgres:5432/<project>_app
# Local dev uses the loopback-published Podman Postgres port generated by ./bootstrap.
# Run migrations after setting: bun run db:migrate
DATABASE_URL=postgres://<project>_app_user:replace-me@<project>-postgres:5432/<project>_app

# Host/operator URL for migrations, backups, restores, and Drizzle Studio.
# Do not use this inside web/worker containers; they use DATABASE_URL above.
DATABASE_DIRECT_URL=postgres://<project>_app_user:replace-me@127.0.0.1:5432/<project>_app

# Bundled Postgres container initialization values. Required for production.
POSTGRES_DB=<project>_app
POSTGRES_USER=<project>_app_user
POSTGRES_PASSWORD=

SESSION_SECRET=

# Optional production runtime tuning. Keep this below Podman/Caddy stop timeout.
SHUTDOWN_TIMEOUT_MS=8000

# ── Contact form ─────────────────────────────────────────────────────────────
# Who receives contact form submissions. Required for email delivery.
# Without these, the console provider logs submissions to stdout.
CONTACT_TO_EMAIL=hello@yourdomain.com
CONTACT_FROM_EMAIL=noreply@yourdomain.com

# Transactional email provider (optional — form saves to DB without it).
# Postmark: set this token to enable real email delivery.
# See src/lib/server/forms/providers/ for other provider options.
POSTMARK_SERVER_TOKEN=

# In-process rate limiter (optional — set to "true" to activate).
# Single-node guard only; resets on restart. See docs/design-system/forms-guide.md.
RATE_LIMIT_ENABLED=false

# ── Automation provider ──────────────────────────────────────────────────────
# n8n is the default and recommended automation path for this template. The
# website captures the lead in Postgres first; the worker delivers to n8n
# from the outbox so a brief n8n outage cannot lose leads. See:
#   docs/automations/README.md
#   docs/automations/n8n-workflow-contract.md
#
# Production preflight (bun run deploy:preflight, bun run check:launch) FAILS
# if AUTOMATION_PROVIDER is unset or = n8n and N8N_WEBHOOK_URL/SECRET are not
# configured. Console mode is rejected in production. Set noop explicitly when
# a site has no automation needs.
AUTOMATION_PROVIDER=n8n

# n8n provider — required when AUTOMATION_PROVIDER=n8n (default).
# WEBHOOK_URL: full webhook URL from the n8n Webhook node.
# WEBHOOK_SECRET: shared secret. Used as the Header Auth value by default.
N8N_WEBHOOK_URL=
N8N_WEBHOOK_SECRET=

# Auth mode for the n8n webhook. Default `header` matches n8n's built-in
# Header Auth credential and works without a Code node. Set to `hmac` to
# switch to HMAC-SHA256 signing of the request body (verifier needs a Code
# node). See docs/automations/n8n-workflow-contract.md for both modes.
N8N_WEBHOOK_AUTH_MODE=header
# Header name used in `header` mode. Configure the matching n8n Header Auth
# credential to expect this name. Default keeps the project consistent.
N8N_WEBHOOK_AUTH_HEADER=X-Site-Auth

# Generic webhook provider — only when AUTOMATION_PROVIDER=webhook.
# Same auth-mode/header conventions apply. Treat this as an escape hatch
# for Make/Zapier/custom receivers; n8n is the documented default.
AUTOMATION_WEBHOOK_URL=
AUTOMATION_WEBHOOK_SECRET=
AUTOMATION_WEBHOOK_AUTH_MODE=header
AUTOMATION_WEBHOOK_AUTH_HEADER=X-Site-Auth

# ── Backups: PITR (production default for the bundled Postgres path) ────────
# The bundled Postgres image (deploy/Containerfile.postgres) ships with WAL-G
# baked in. WAL archives stream to R2 every minute and base backups land
# nightly. See docs/operations/backups.md for the full workflow and
# docs/operations/architecture.md for where this fits.
#
# All R2_* values are required for production; WAL-G backs up the dedicated
# per-site Postgres cluster.
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
R2_BUCKET=
# Sub-path inside the bucket. Use one prefix per site so backups never
# collide if multiple sites share a bucket.
R2_PREFIX=<project-slug>/postgres

# PITR retention window in days. The base-backup retention prune keeps at
# least one base backup at least this old, plus all newer base backups and
# the WAL needed to replay forward from any of them. 14 days matches n8n's
# default execution-data prune horizon.
PITR_RETENTION_DAYS=14

# ── Backups: legacy logical dumps (still supported as a convenience path) ───
# pg_dump snapshots remain useful for one-shot exports (sending a copy to a
# client, manual schema diffing). PITR is the production reliability path.
# rclone remote spec, e.g. r2:bucket-name/site-backups
BACKUP_REMOTE=

# Healthchecks.io ping URL (or compatible service like Better Uptime, Cronitor).
# When set, backup:push and backup:base ping <url>/start, <url> on success,
# <url>/fail on error. Without this, silent backup failures will not alert.
BACKUP_HEALTHCHECK_URL=

# ── n8n self-hosted bundle (optional, per-client when activated) ────────────
# The site's automation worker can deliver to ANY n8n instance via
# N8N_WEBHOOK_URL above. These settings are only relevant when this
# specific client also runs its OWN n8n bundle on this host. Run
# bun run n8n:enable to provision the n8n schema, role, and starter env.
# See docs/automations/n8n-workflow-contract.md → "Per-client bundle".
N8N_ENABLED=false
# 32-byte URL-safe random key. Generate once with:
#   openssl rand -hex 32
# Losing or rotating this key invalidates every credential stored inside
# n8n's database. Treat it like the database password.
N8N_ENCRYPTION_KEY=
# Public URL of this client's n8n editor (e.g. https://n8n.client-domain.com).
# Lock the editor down behind Caddy basic auth or a VPN — the webhook
# endpoint can be public, the editor must not be.
N8N_HOST=
N8N_PROTOCOL=https
# n8n database role password created by bun run n8n:enable. n8n uses a separate
# database and role inside this client's dedicated Postgres cluster.
DB_POSTGRESDB_PASSWORD=

# ── Analytics (public — safe to expose to browser) ──────────────────────────
# See docs/analytics/README.md for the full analytics guide.
# Master switch — set to "true" only for production. Leave false for staging/dev.
PUBLIC_ANALYTICS_ENABLED=false
# GTM web container ID (e.g. GTM-XXXXXXX). Required when analytics is enabled.
PUBLIC_GTM_ID=
# GA4 Measurement ID (e.g. G-XXXXXXXXXX). Informational — GA4 lives inside GTM.
PUBLIC_GA4_MEASUREMENT_ID=
# Cloudflare Web Analytics token — optional privacy-first sanity layer.
PUBLIC_CLOUDFLARE_WEB_ANALYTICS_TOKEN=
# Set to "true" to allow analytics in staging/preview (not recommended).
PUBLIC_ANALYTICS_STAGING_OVERRIDE=false

# ── Analytics (private — server-side conversion events, dormant by default) ──
# See docs/analytics/server-conversions.md before enabling.
ANALYTICS_SERVER_EVENTS_ENABLED=false
# GA4 Measurement ID and API secret for server-side Measurement Protocol events.
# Only needed if using the GA4 MP provider (see ga4-measurement-protocol.example.ts).
GA4_MEASUREMENT_ID=
GA4_MEASUREMENT_PROTOCOL_API_SECRET=
