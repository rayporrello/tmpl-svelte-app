# deploy/quadlets/postgres.volume — persistent Postgres data volume for <project>
#
# Usage:
#   1. Run `bun run init:site` to replace <project> placeholders.
#   2. Copy to ~/.config/containers/systemd/<project>-postgres-data.volume
#   3. systemctl --user daemon-reload
#   4. The volume is created automatically when <project>-postgres starts.

[Unit]
Description=Postgres data volume — <project>

[Volume]
VolumeName=<project>-postgres-data
