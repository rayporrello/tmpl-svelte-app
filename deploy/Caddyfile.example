# deploy/Caddyfile.example — Caddy reverse proxy for a SvelteKit site
#
# Replace example.com with the real domain before use.
# See docs/deployment/runbook.md for the full deployment procedure.
#
# Security header ownership (ADR-018, ADR-019):
#   Caddy owns:  TLS, compression, access logging
#   App owns:    CSP, X-Frame-Options, Referrer-Policy, Permissions-Policy
#   Both set:    HSTS — Caddy is canonical; app provides defense-in-depth so
#                HSTS is preserved if deployed behind a different proxy
#                (Cloudflare Tunnel, Fly proxy, etc.).
#   Do NOT duplicate app-owned headers here — the app already sets them.

example.com {
    # ── TLS ───────────────────────────────────────────────────────────────────
    # Let's Encrypt automatic certificate via ACME HTTP-01 challenge.
    # No configuration needed — Caddy handles it automatically.
    tls {
        protocols tls1.2 tls1.3
    }

    # ── HSTS ─────────────────────────────────────────────────────────────────
    # Caddy is canonical for HSTS. The app also sets the same value on HTTPS
    # responses as defense-in-depth when deployed behind a different proxy.
    # Adjust max-age/includeSubDomains here and in src/hooks.server.ts together
    # before adding a domain to the preload list.
    header Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"

    # ── Compression ──────────────────────────────────────────────────────────
    # Caddy owns compression. Do not compress in the app.
    encode zstd gzip

    # ── Access logging ────────────────────────────────────────────────────────
    # Log to stdout so journald captures it via the Caddy systemd unit.
    log {
        output stdout
        format json
    }

    # ── Rate limiting (optional) ─────────────────────────────────────────────
    # The app's in-memory token bucket (set RATE_LIMIT_ENABLED=true) is a
    # single-node guard that resets on restart and is not shared across
    # instances. For durable or multi-node protection add a layer here:
    #
    #   Cloudflare (recommended): create a WAF rate-limit rule in the
    #     dashboard for POST /contact*. Free tier covers normal abuse loads
    #     and requires no Caddy module.
    #
    #   Caddy: install xcaddy + mholt/caddy-ratelimit, then enable below.
    #
    # rate_limit {
    #     zone contact_post {
    #         match {
    #             method POST
    #             path /contact*
    #         }
    #         key {client_ip}
    #         events 5
    #         window 1m
    #     }
    # }

    # ── Immutable SvelteKit assets (optional) ────────────────────────────────
    # SvelteKit's generated /_app/immutable/* filenames are content-hashed.
    # The Bun adapter normally serves them with long-lived cache headers; keep
    # this edge snippet here as the explicit Caddy-side override if a future
    # adapter/proxy path stops doing so.
    #
    # @svelte_immutable path /_app/immutable/*
    # header @svelte_immutable Cache-Control "public, max-age=31536000, immutable"

    # ── Reverse proxy ─────────────────────────────────────────────────────────
    # The SvelteKit app listens on port 3000. In a Podman Quadlet setup the
    # container is reachable at 127.0.0.1:3000 (or via container hostname if
    # Caddy is on the same Podman network).
    reverse_proxy 127.0.0.1:3000 {
        # Health check — Caddy marks the upstream as healthy before serving.
        health_uri /healthz
        health_interval 10s
        health_timeout 3s
    }
}

# Redirect www → apex (optional — remove if not using www)
www.example.com {
    redir https://example.com{uri} permanent
}
