# deploy/env.example — Runtime environment variables for the container / Quadlet
#
# These are the env vars the SvelteKit app needs at runtime (svelte-adapter-bun).
# This file is NOT a secrets file. Secret values (API keys, DB passwords, etc.)
# are managed separately via SOPS + age — see docs/deployment/secrets.md.
#
# Usage:
#   1. Copy this file to the appropriate location on your host, e.g.:
#        cp deploy/env.example ~/secrets/<project>.prod.env
#   2. Fill in real values (the Quadlet reads from EnvironmentFile)
#   3. Never commit the populated file — it will contain real secrets

# ── Required ──────────────────────────────────────────────────────────────────

# Full origin URL for CSRF protection and URL construction.
# Must match the domain Caddy is serving (no trailing slash).
ORIGIN=https://example.com

# Public site URL (used by the app for canonical links, OG images, etc.).
# Usually the same as ORIGIN.
PUBLIC_SITE_URL=https://example.com

# ── Optional ──────────────────────────────────────────────────────────────────

# Port the server listens on inside the container.
# Caddy proxies to this port; do NOT expose it publicly.
PORT=3000

# Bind address (default: 0.0.0.0). In a Podman network, 0.0.0.0 is fine
# because only Caddy can reach the container via the project network.
HOST=0.0.0.0

# Header to read client IP from when behind Caddy or another proxy.
# ADDRESS_HEADER=True-Client-IP

# Trusted proxy depth for X-Forwarded-For (default: 1).
# XFF_DEPTH=1

# ── Secrets (managed via SOPS + age) ─────────────────────────────────────────
# Do NOT add secret values here. Add variable names to:
#   .env.example          — public contract for variable names
#   secrets.example.yaml  — representative fake values (committed)
#   secrets.yaml          — real encrypted values (committed, SOPS-encrypted)
# Then render to ~/secrets/<project>.prod.env via bun run secrets:render
