# deploy/env.example — Runtime environment variables for the container / Quadlet
#
# These are the env vars the SvelteKit app needs at runtime (svelte-adapter-bun).
# This file is NOT a secrets file. Production values are rendered by the
# separate platform-infrastructure repo to ~/secrets/<slug>.prod.env.
#
# Usage:
#   1. Copy this file to the appropriate location on your host, e.g.:
#        cp deploy/env.example ~/secrets/<project>.prod.env
#   2. Fill in real values (the Quadlet reads from EnvironmentFile)
#   3. Never commit the populated file — it will contain real secrets

# ── Required ──────────────────────────────────────────────────────────────────

# Full origin URL for CSRF protection and URL construction.
# Must match the domain Caddy is serving (no trailing slash).
ORIGIN=https://example.com

# Public site URL (used by the app for canonical links, OG images, etc.).
# Usually the same as ORIGIN.
PUBLIC_SITE_URL=https://example.com

# Platform client slug and app/runtime database URL. Web containers join
# web-platform.network and reach the shared Postgres cluster by hostname.
CLIENT_SLUG=<project>
DATABASE_URL=postgres://<project>_app_user:replace-me@web-platform-postgres:5432/<project>_app
DATABASE_POOL_MAX=5
DATABASE_STATEMENT_TIMEOUT_MS=5000

# Contact form lead notification. Required for production launch by ADR-024.
CONTACT_TO_EMAIL=hello@yourdomain.com
CONTACT_FROM_EMAIL=noreply@yourdomain.com
POSTMARK_SERVER_TOKEN=replace-me

# Authenticated E2E deploy smoke (ADR-029). SMOKE_TEST_SECRET is a privileged
# backdoor credential for smoke submissions to /contact; generate with
# `openssl rand -hex 32` and rotate per docs/operations/smoke.md. When set,
# POSTMARK_API_TEST is required so smoke email uses Postmark's test token.
SMOKE_TEST_SECRET=
POSTMARK_API_TEST=
SMOKE_TEST_RATE_LIMIT_PER_HOUR=60
SMOKE_TEST_BACKLOG_THRESHOLD=100

# Operator auth for /admin/* is enforced by Caddy basicauth. Generate with
# `caddy hash-password`, store only this hash, and never store cleartext.
HEALTH_ADMIN_PASSWORD_HASH=replace-me-with-caddy-hash

# Explicit waiver for non-lead-gen variants or temporary repair mode only.
# Normal production launches should leave this at 0 and configure Postmark.
LAUNCH_ALLOW_CONSOLE_EMAIL=0

# Production automation provider config is owned by platform-infrastructure.
# The website repo keeps AUTOMATION_* / N8N_* only for local one-shot worker dev.

# ── Optional ──────────────────────────────────────────────────────────────────

# Port the server listens on inside the container.
# Caddy proxies to this port; do NOT expose it publicly.
PORT=3000

# Bind address (default: 0.0.0.0). The web Quadlet publishes this port to
# 127.0.0.1 only; Caddy is the public entrypoint.
HOST=0.0.0.0

# Graceful shutdown drain window used by serve.js. Keep below the web Quadlet's
# StopTimeout so Podman does not escalate to SIGKILL during normal restarts.
SHUTDOWN_TIMEOUT_MS=8000

# Header to read client IP from when behind Caddy or another proxy.
# ADDRESS_HEADER=True-Client-IP

# Trusted proxy depth for X-Forwarded-For (default: 1).
# XFF_DEPTH=1

# ── Secrets (managed via SOPS + age) ─────────────────────────────────────────
# Do NOT add secret values here. Production secret rendering is platform-owned.
